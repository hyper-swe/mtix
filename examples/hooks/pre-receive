#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# mtix pre-receive hook — DEFERRED FOR v0.2.0-beta (MTIX-15 / FR-18)
#
# In the v0.1.x design, this hook regenerated `.mtix/tasks.json` from
# Postgres on the git server and rejected pushes whose committed snapshot
# disagreed with the live PG state. That model assumed Postgres was the
# canonical store.
#
# v0.2.0-beta ships the FR-18 sync model instead: the canonical store is
# each developer's LOCAL SQLite; the Postgres hub is an event-sourced
# replication mechanism, not a snapshot source. Server-side validation
# in this new model needs a redesign — the git server doesn't have a
# local SQLite to compare against, only the hub.
#
# Until the v0.2.1 redesign lands, server-side enforcement is **deferred**.
# This hook is a no-op stub that exits 0 cleanly so installations that
# already wired it don't break their git push pipeline.
#
# Alternatives available in v0.2.0-beta
#   1. Run `mtix sync daemon` as a systemd/launchd service on every
#      developer's machine — bounds the un-pushed-event window to the
#      daemon's interval (default 30s).
#   2. Install `examples/hooks/pre-push` on every developer's machine
#      (client-side; bypassable with `--no-verify` but covers the
#      common case).
#   3. Add a CI job that runs `mtix sync doctor --json` against the hub
#      DSN and fails if any check fails. Gate merges via branch protection
#      requiring that job to pass.
#
# See docs/SECURITY-MODEL.md, docs/SYNC-DESIGN.md, and CHANGELOG.md
# v0.2.0-beta entry. Tracked for v0.2.1.
# ---------------------------------------------------------------------------

set -euo pipefail

printf 'mtix pre-receive: server-side enforcement deferred to v0.2.1 (MTIX-15 / FR-18 redesign in progress); accepting push\n' >&2

# Consume stdin to satisfy git's hook contract (it pipes ref-updates here).
while read -r _line; do
  :
done

exit 0
