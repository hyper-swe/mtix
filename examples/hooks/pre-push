#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# mtix pre-push hook (client-side) — FR-18 sync model
#
# Role
#   Before each `git push`, drain the local sync_events queue to the BYO
#   Postgres hub so teammates pulling will see the latest state.
#   Optionally also refresh `.mtix/tasks.json` from the local SQLite so
#   the committed snapshot matches the pushed events.
#
# Mode
#   Client-side hook. Developers can bypass with `--no-verify` or by
#   editing their own `.git/hooks/pre-push`. For environments where the
#   sync must be enforced, also install `pre-receive` (self-hosted git)
#   or `github-action.yml` (GitHub.com). See `examples/hooks/README.md`
#   and `docs/SECURITY-MODEL.md` for the full trust model.
#
# Failure mode (intentional, non-negotiable)
#   If `mtix sync push` fails (hub unreachable, transient PG error), the
#   hook *warns and skips* — it does NOT block `git push`. Blocking
#   would couple your ability to push code to hub availability, which
#   is the wrong default for a primitives-not-policy tool.
#
#   We set `MTIX_SYNC_HOOK=1` before invoking the CLI so the sync code
#   path classifies transient errors as warn-and-skip (per FR-18.19 /
#   wrapSyncErr in cmd/mtix/sync_init.go) and returns 0 instead of 1.
#
# Security posture
#   T1: every variable is double-quoted; no `eval`; no unquoted command
#       substitution into shell commands.
#   T2: `mtix` is resolved once via `command -v` and then invoked via
#       the absolute path stored in `MTIX_BIN`, which is `export`ed so
#       any subprocess uses the same binary. This prevents a malicious
#       cwd from shadowing `mtix` via a poisoned `./mtix`.
#   T3: never echoes hub DSN or any event content; only structural
#       messages (file paths under `.mtix/`, exit status). The CLI's
#       own DSN redaction (redact.DSN) covers what it prints.
#   S1: sync failure is non-fatal to the push (`MTIX_SYNC_HOOK=1`).
#   S2: push is invoked through the normal CLI which honors the
#       transport retry / timeout envelope.
#
# Install
#   cp examples/hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# Required environment
#   The mtix CLI must be on PATH at install time so the resolution call
#   below succeeds. Override by exporting MTIX_BIN to an absolute path
#   before running git push.
#
#   The sync DSN must be reachable to mtix via MTIX_SYNC_DSN env or
#   .mtix/secrets (mode 0600). If neither is set, the hook warns and
#   exits 0 — sync is opt-in.
# ---------------------------------------------------------------------------
#
# Provisional-id externalization guardrail (ADR-003 §8)
#   A node display_path that still carries a uid segment is *provisional*:
#   valid and resolvable now, but its number is not yet settled and WILL
#   change. Embedding a provisional id in an immutable artifact (a commit
#   message, here) leaves a dangling reference once it settles. Before the
#   push goes out we scan the outgoing commit messages for provisional ids,
#   detectable from the id SHAPE alone (a `.u<hex>` segment), and warn.
#   Default is warn-and-continue (primitives, not policy). Export
#   MTIX_BLOCK_PROVISIONAL=1 to escalate the warning into a hard refusal.
# ---------------------------------------------------------------------------

set -euo pipefail

# --- T2: resolve mtix once, then use absolute path everywhere --------------
if [ -z "${MTIX_BIN:-}" ]; then
  if ! MTIX_BIN="$(command -v mtix)"; then
    printf 'mtix pre-push: mtix CLI not found on PATH; skipping sync\n' >&2
    exit 0
  fi
fi
export MTIX_BIN

# --- Pre-flight --------------------------------------------------------------
# Only run inside a project that uses mtix.
if [ ! -d ".mtix" ]; then
  exit 0
fi

# --- Provisional-id externalization guardrail (ADR-003 §8) ------------------
# Read the ref updates git feeds on stdin ("<localref> <localsha>
# <remoteref> <remotesha>") and scan the outgoing commit messages for a
# provisional id shape. Shape-only detection, consistent with
# model.IsProvisional: a node id whose dot-path carries a uid segment
# (the marker 'u' followed by lowercase hex), e.g. PRJX-1.u0a1b2c3d4e5 or
# PRJX-1.2.u0a1b2c3d4e5.4. A fully-numeric id (PRJX-1.4) is settled and
# safe to externalize, so it never matches.
PROVISIONAL_RE='[A-Za-z][A-Za-z0-9-]*-[0-9]+(\.[0-9a-z]+)*\.u[0-9a-f]+'
ZERO_SHA='0000000000000000000000000000000000000000'

scan_range_for_provisional() {
  # Args ($@) = git rev-list revision selectors. Prints offending
  # "<sha> <subject> [<ids>]" lines (one per commit that embeds a
  # provisional id) to stdout. Each selector is passed as its own argv
  # word so multi-token ranges (e.g. "<sha> --not --remotes") are not
  # collapsed into a single malformed revision.
  git rev-list "$@" 2>/dev/null | while IFS= read -r sha; do
    msg="$(git log -1 --format='%B' "${sha}" 2>/dev/null || true)"
    hit="$(printf '%s' "${msg}" | grep -Eo "${PROVISIONAL_RE}" || true)"
    if [ -n "${hit}" ]; then
      subject="$(git log -1 --format='%s' "${sha}" 2>/dev/null || true)"
      printf '%s %s [%s]\n' "${sha}" "${subject}" \
        "$(printf '%s' "${hit}" | tr '\n' ',' | sed 's/,$//')"
    fi
  done
}

PROVISIONAL_FOUND=0
while read -r _localref localsha _remoteref remotesha; do
  [ -z "${localsha:-}" ] && continue
  # A branch deletion (local sha all zeros) externalizes nothing.
  [ "${localsha}" = "${ZERO_SHA}" ] && continue
  if [ "${remotesha:-${ZERO_SHA}}" = "${ZERO_SHA}" ]; then
    # New ref on the remote: scan every commit reachable from the local sha
    # that is not already on any other remote-tracking branch.
    offenders="$(scan_range_for_provisional "${localsha}" --not --remotes)"
  else
    # Updating an existing ref: scan only the newly-pushed commits.
    offenders="$(scan_range_for_provisional "${remotesha}..${localsha}")"
  fi
  if [ -n "${offenders}" ]; then
    PROVISIONAL_FOUND=1
    printf 'mtix pre-push: provisional id(s) found in outgoing commit messages (ADR-003 §8):\n' >&2
    printf '%s\n' "${offenders}" >&2
  fi
done

if [ "${PROVISIONAL_FOUND}" = "1" ]; then
  printf 'mtix pre-push: provisional ids are not yet settled and their numbers WILL change;\n' >&2
  printf '  re-resolve via mtix and use the settled (fully-numeric) id before externalizing.\n' >&2
  if [ "${MTIX_BLOCK_PROVISIONAL:-0}" = "1" ]; then
    printf 'mtix pre-push: MTIX_BLOCK_PROVISIONAL=1 set — refusing the push.\n' >&2
    exit 1
  fi
  printf 'mtix pre-push: continuing (warn-only); set MTIX_BLOCK_PROVISIONAL=1 to refuse.\n' >&2
fi

# Sync is opt-in. If no DSN is configured, skip silently.
if [ -z "${MTIX_SYNC_DSN:-}" ] && [ ! -f ".mtix/secrets" ]; then
  exit 0
fi

# --- S1: warn-and-skip on transient sync failures --------------------------
# MTIX_SYNC_HOOK=1 tells the sync code path to treat transient errors
# (connection refused, TLS handshake timeout, etc.) as warnings rather
# than fatal errors. Schema mismatch and authentication errors still
# fail the push — those are operator misconfigurations, not transient.
export MTIX_SYNC_HOOK=1

if ! "${MTIX_BIN}" sync push 2>&1; then
  # Should never happen given MTIX_SYNC_HOOK=1 swallows transients, but
  # keep belt-and-suspenders: a non-zero return from `mtix sync push`
  # in hook mode indicates a real misconfiguration. Print and skip; do
  # NOT block the push.
  printf 'mtix pre-push: sync push failed in hook mode; push continues\n' >&2
  exit 0
fi

# --- Optional: refresh .mtix/tasks.json --------------------------------------
# After a successful push the local SQLite and the hub are in sync; also
# refresh the git-tracked snapshot so the human-readable view in the
# repo reflects the latest state.
TASKS_FILE=".mtix/tasks.json"
PRE_HASH=""
if [ -f "${TASKS_FILE}" ]; then
  PRE_HASH="$(git hash-object "${TASKS_FILE}")"
fi

if ! "${MTIX_BIN}" sync --fix >/dev/null 2>&1; then
  # tasks.json refresh failed — not load-bearing for push correctness.
  exit 0
fi

POST_HASH=""
if [ -f "${TASKS_FILE}" ]; then
  POST_HASH="$(git hash-object "${TASKS_FILE}")"
fi

if [ "${PRE_HASH}" = "${POST_HASH}" ]; then
  exit 0
fi

# --- Stage the change --------------------------------------------------------
git add -- "${TASKS_FILE}"

TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
COMMIT_MSG="chore(snapshot): tasks.json refresh @ ${TIMESTAMP}"

if [ "${MTIX_HOOK_AMEND:-0}" = "1" ]; then
  git commit --amend --no-edit --no-verify --quiet
else
  git commit --quiet --no-verify -m "${COMMIT_MSG}"
fi

NEW_SHA="$(git rev-parse --short HEAD)"
printf 'mtix pre-push: sync push + snapshot committed (%s) %s\n' "${NEW_SHA}" "${TASKS_FILE}" >&2

exit 0
